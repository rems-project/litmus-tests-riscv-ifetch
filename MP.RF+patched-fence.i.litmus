RISCV MP.RF+patched-fence.i
Variant=self
{ 0:t0 = instr:"li s0, 5"; 0:t1 = instr:"fence.i"; 0:t2 = 1;
  0:a1 = P1:mod; 0:a2 = P1:fi_slot; 0:a3 = flag;
  1:a1 = flag; 1:s0 = 0; }
P0           | P1           ;
sw t0,0(a1)  | lw s2,(a1)   ;
sw t1,0(a2)  | fi_slot:     ;
fence w,w    | nop          ;
sw t2,0(a3)  | mod:         ;
             | nop          ;
exists (1:s2=1 /\ 1:s0=0)
