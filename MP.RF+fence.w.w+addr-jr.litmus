RISCV MP.RF+fence.w.w+addr-jr
(* adapted from Brendan's DIC.miniJit01.litmus *)
Variant=self
{ [x]=P1:L0;
  0:t0=instr:"li s0, 3"; 0:a1=P1:L1; 0:a2=x;
  1:a2=x; 1:s0=0; }
P0           | P1           ;
sw t0,0(a1)  | ld s1,(a2)   ;
fence w,w    | jr s1        ;
sd a1,0(a2)  | L0:          ;
             | li s0, 1     ;
             | j Lend       ;
             | L1:          ;
             | li s0, 2     ;
             | Lend:        ;
exists (1:s0=2)
