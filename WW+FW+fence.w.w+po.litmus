RISCV WW+FW+fence.w.w+po
(* adapted from Brendan's DIC.MP.FW+po.litmus *)
Variant=self
{ 0:t0=instr:"li s0, 1"; 0:a1=P1:mod; 0:a2=x; 0:t1=1;
  1:a2=x; 1:t2=2; 1:s0=0; }
P0           | P1           ;
sw t1,0(a2)  | mod:         ;
fence w,w    | nop          ;
sw t0,0(a1)  | sw t2,0(a2)  ;
exists (1:s0=1 /\ x=1)
