RISCV SM+RW
Variant=self
{ 0:t0=instr:"li s0, 2"; 0:a1=P0:mod; 0:a2=x;
  1:t1=instr:"li s0, 3"; 1:a1=P0:mod; 1:a2=x; 1:t3=1; }
P0           | P1               ;
sw t0,0(a1)  | lw s2,0(a1)      ;
lw s1,(a2)   | sw t1,0(a1)      ;
fence.i      | lw s3,0(a1)      ;
mod:         | xor t2,s3,s3     ;
li s0, 1     | add a3,a2,t2     ;
             | sw t3,0(a3)      ;
exists (0:s1=1 /\ 1:s2=instr:"li s0, 2" /\ 1:s3=instr:"li s0, 3" /\ 0:s0=2)
