RISCV MP+irf+data+fence.r.r
Variant=self
{ 0:t0=instr:"li s0, 2"; 0:a1=P0:mod; 0:a2=x;
  1:a1=P0:mod; 1:a2=x; }
P0           | P1           ;
sw t0,0(a1)  | lw s1,(a2)   ;
mod:         | fence r,r    ;
li s0, 1     | lwu s2,0(a1) ;
sw s0,0(a2)  |              ;
exists (1:s1=2 /\ 1:s2=instr:"li s0, 1")
