RISCV CoFF+fencei
Variant=self
{ 0:t0=instr:"li t6, 2"; 0:a1=P1:mod; }
P0           | P1                ;
sw t0,0(a1)  | jal mod           ;
             | mv s0, t6         ;
             | fence.i           ;
             | jal mod           ;
             | mv s1, t6         ;
             | j end             ;
             | mod:              ;
             | li t6, 1          ;
             | jr ra             ;
             | end:              ;
exists (1:s0=2 /\ 1:s1=1)
