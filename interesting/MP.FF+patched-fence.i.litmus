RISCV MP.FF+patched-fence.i
Variant=self
{ 0:t0=instr:"li s9, 1"; 0:t1=instr:"fence.i";
  0:a1=P1:mod; 0:a2=P1:fi_slot;
  1:s8=0; 1:s9=0; }
P0           | P1           ;
sw t0,0(a1)  | fi_slot:     ;
fence w,w    |  j end       ;
sw t1,0(a2)  |  li s8, 1    ;
             | mod:         ;
             |  nop         ;
             | end:         ;
exists (1:s8=1 /\ 1:s9=0)
