RISCV MP.FR+fence.w.w+reg-addr
(* adapted from Brendan's IDC.fetchtoexecutechained.litmus *)
Variant=self
{ 0:t2=1; 0:a3=z; 0:a1=P1:mod; 0:t0=instr:"mv a3, t1";
  1:a1=P1:mod; 1:a3=z; 1:t0=x; 1:t1=z; 1:s9=0;
  x=2; }
P0           | P1            ;
sw t2,0(a3)  | mod:          ;
fence w,w    |  mv a3, t0    ;
sw t0,0(a1)  |  lw s9, 0(a3) ;
exists (1:s9=0)
