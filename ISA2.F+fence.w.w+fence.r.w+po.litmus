RISCV ISA2.F+fence.w.w+fence.r.w+po
Variant=self
{ 0:t0=instr:"li s2, 5"; 0:a1=P2:mod; 0:a2=y; 0:t1=1;
  1:a1=y; 1:a2=z; 1:t1=1;
  2:a1=z; }
