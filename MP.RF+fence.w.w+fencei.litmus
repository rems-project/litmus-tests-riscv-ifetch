RISCV MP.RF+fence.w.w+fencei
(* adapted from Brendan's IDC.MP.RF+fencei.litmus *)
Variant=self
{ 0:t0=instr:"li s0, 5"; 0:a1=P1:mod; 0:a2=flag; 0:t1=1; 1:a2=flag; 1:s0=0; }
P0           | P1           ;
sw t0,0(a1)  | lw s2,(a2)   ;
fence w,w    | fence.i      ;
sw t1,0(a2)  | mod:         ;
             | nop          ;
exists (1:s2=1 /\ 1:s0=0)
